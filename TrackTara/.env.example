# Копіюйте у .env і підставте значення.

# Демо без бекенду (Vercel): VITE_USE_MOCK_API=true (за замовчуванням теж true).
# Реальний API — лише якщо явно VITE_USE_MOCK_API=false.
VITE_USE_MOCK_API=true

# OAuth 2.0 Client ID (Web) з Google Cloud Console.
# У Credentials → ваш клієнт → Authorized JavaScript origins:
#   http://localhost:5173  та  https://ваш-домен.vercel.app (без шляху в кінці).
# У режимі Testing логін лише для акаунтів з OAuth consent screen → Test users.
VITE_GOOGLE_CLIENT_ID=

# Спільний хост для legacy REST (категорії, виробники, позиції кошика) та дефолт для зображень товарів.
# VITE_API_LEGACY_ORIGIN=http://13.60.245.135:4312
# Окремо: зображення товарів (база без /Images/...).
# VITE_API_PRODUCT_IMAGES_ORIGIN=http://13.60.245.135:4312
# Сектори складу при VITE_USE_MOCK_API=false (get-all, create, delete/:sector, add-row, remove-row/...).
# VITE_API_SECTORS_URL=http://localhost:5081/sectors

# Операційні API (опційно). Якщо VITE_USE_MOCK_API=false і бекенд ще без цих контролерів,
# клієнт автоматично використовує персистентне мок-сховище (localStorage), як у демо.
# VITE_API_BRAKIMAG_URL=http://localhost:5081/brakimag
# VITE_API_CART_REGISTRY_URL=http://localhost:5081/cart-registry
# VITE_API_PACKING_BOXES_URL=http://localhost:5081/packing-boxes
