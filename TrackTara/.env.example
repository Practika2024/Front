# Копіюйте у .env і підставте значення.

# true — мок-API (демо без бекенду). У production-білді моки лише якщо явно true.
VITE_USE_MOCK_API=true

# OAuth 2.0 Client ID (Web) з Google Cloud Console.
# У Credentials → ваш клієнт → Authorized JavaScript origins:
#   http://localhost:5173  та  https://ваш-домен.vercel.app (без шляху в кінці).
# У режимі Testing логін лише для акаунтів з OAuth consent screen → Test users.
VITE_GOOGLE_CLIENT_ID=
